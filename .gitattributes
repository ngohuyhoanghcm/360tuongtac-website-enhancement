# Binary file declarations - prevent Git from corrupting binary data
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svg text eol=lf

# Source code - force LF line endings
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Build artifacts
.next/ -diff -merge
node_modules/ -diff -merge
coverage/ -diff -merge
